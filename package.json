{
  "name": "@pandopia/cli",
  "version": "0.1.2",
  "description": "CLI pour l'API catalogue Pandopia",
  "bin": {
    "pandopia": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "reference"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test:unit": "npm run build && node --test",
    "test:coverage": "npm run build && node scripts/check-coverage.mjs",
    "test": "npm run test:coverage",
    "publish:npm": "npm publish --access public",
    "publish:ci": "node scripts/publish-if-needed.mjs"
  },
  "coverageThreshold": {
    "lines": 100
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.19",
    "typescript": "^5.8.2"
  }
}
